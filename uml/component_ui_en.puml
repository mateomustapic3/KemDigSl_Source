@startuml
top to bottom direction
skinparam componentStyle rectangle

package "KemDigSl" {
  [WinForms UI] as UI
  [Main menu] as Menu
  [Forms 1-11] as Forms
  [Helper classes] as Paths
  [CrashLogger] as Logger
}

